# Mamba Latent Reasoning Engine — .gitignore

# Model checkpoints (too large for git)
checkpoints/
*.pth
*.safetensors
*.bin

# Session state
sessions/

# Training data (generated by build scripts)
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
grpo_env/

# Logs
*.log
wandb/
monitor.log
daemon_watch.log

# Jupyter
*.ipynb_checkpoints

# Debug / temp outputs
latent_diagnostics.jsonl
training_report.json

# OS
.DS_Store
